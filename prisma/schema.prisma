// prisma/schema.prisma
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model ContactSubmission {
  id        String   @id @default(cuid())
  fullName  String
  phone     String
  email     String
  message   String?
  status    String   @default("new") // new | contacted | closed
  createdAt DateTime @default(now())

  @@index([createdAt])
}